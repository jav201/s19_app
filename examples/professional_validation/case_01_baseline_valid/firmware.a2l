/begin PROJECT CASE01 "Synthetic professional dataset for S19Tool"
  /begin HEADER
    VERSION "1.0"
    PROJECT_NO 1
  /end HEADER

  /begin MODULE BASELINE "Synthetic ECU module"
    /begin MOD_COMMON ""
      BYTE_ORDER MSB_FIRST
      ALIGNMENT_BYTE 1
      ALIGNMENT_WORD 2
      ALIGNMENT_LONG 4
      ALIGNMENT_FLOAT32_IEEE 4
    /end MOD_COMMON

    /begin MOD_PAR ""
      EPK "S19TOOL_PRO_SUITE"
    /end MOD_PAR

    /begin RECORD_LAYOUT RL_U8
      FNC_VALUES 1 UBYTE COLUMN_DIR DIRECT
    /end RECORD_LAYOUT

    /begin RECORD_LAYOUT RL_U16
      FNC_VALUES 1 UWORD COLUMN_DIR DIRECT
    /end RECORD_LAYOUT

    /begin RECORD_LAYOUT RL_U32
      FNC_VALUES 1 ULONG COLUMN_DIR DIRECT
    /end RECORD_LAYOUT

    /begin COMPU_METHOD CM_IDENT "%6.2" IDENTICAL "%6.2" ""
      COEFFS 0 1 0 0 0 1
    /end COMPU_METHOD

/begin CHARACTERISTIC HEADER_OK "HEADER_OK synthetic characteristic"
  VALUE 0x80000000 RL_U8 0 CM_IDENT 0 255
/end CHARACTERISTIC
/begin CHARACTERISTIC CAL_A "CAL_A synthetic characteristic"
  VALUE 0x80000010 RL_U8 0 CM_IDENT 0 255
/end CHARACTERISTIC
/begin CHARACTERISTIC CAL_B "CAL_B synthetic characteristic"
  VALUE 0x80000080 RL_U8 0 CM_IDENT 0 255
/end CHARACTERISTIC
/begin GROUP GRP_BASELINE "GRP_BASELINE synthetic group"
  /begin REF_CHARACTERISTIC
  HEADER_OK
  CAL_A
  CAL_B
  /end REF_CHARACTERISTIC
/end GROUP
  /end MODULE
/end PROJECT
