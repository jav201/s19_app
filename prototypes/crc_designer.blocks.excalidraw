      "text": "{\n  \"schema_version\": 1,\n  \"name\": \"CRC-32/ISO-HDLC\",\n  \"aliases\": [\"zlib\", \"PKZIP\", \"CRC-32\"],\n  \"operation\": \"crc\",\n  \"algorithm\": {\n    \"width\": 32, \"poly\": \"0x04C11DB7\",\n    \"init\": \"0xFFFFFFFF\", \"refin\": true,\n    \"refout\": true, \"xorout\": \"0xFFFFFFFF\",\n    \"check\": \"0xCBF43926\"\n  }\n}",
