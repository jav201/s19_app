    {
      "type": "text", "id": "impl_body", "x": 1104, "y": 584, "width": 296, "height": 90,
      "text": "• 256-entry LUT built at init from poly\n   (+reflection); bit-by-bit = KAT oracle\n• shift: reflected → LSB-first, else MSB-first\n• same result either way — engine detail,\n   never a JSON knob (#1, #4)",
      "originalText": "• 256-entry LUT built at init from poly\n   (+reflection); bit-by-bit = KAT oracle\n• shift: reflected → LSB-first, else MSB-first\n• same result either way — engine detail,\n   never a JSON knob (#1, #4)",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
