      "type": "text", "id": "job_json", "x": 920, "y": 774, "width": 690, "height": 270,
      "text": "{\n  \"schema_version\": 1,\n  \"algorithm_ref\": \"CRC-32/ISO-HDLC\",\n  \"targets\": [{\n    \"ranges\": [\n      {\"start\": \"0x8000\", \"end\": \"0x8008\"},\n      {\"start\": \"0x8010\", \"end\": \"0x8018\"}\n    ],\n    \"intra_gap\": \"skip\",  \"join\": \"fill\",\n    \"pad_byte\": \"0xFF\",\n    \"on_gap_conflict\": \"abort\",\n    \"output_address\": \"0x8018\",\n    \"store_width\": 4,  \"store_endianness\": \"little\"\n  }]\n}",
      "originalText": "{\n  \"schema_version\": 1,\n  \"algorithm_ref\": \"CRC-32/ISO-HDLC\",\n  \"targets\": [{\n    \"ranges\": [\n      {\"start\": \"0x8000\", \"end\": \"0x8008\"},\n      {\"start\": \"0x8010\", \"end\": \"0x8018\"}\n    ],\n    \"intra_gap\": \"skip\",  \"join\": \"fill\",\n    \"pad_byte\": \"0xFF\",\n    \"on_gap_conflict\": \"abort\",\n    \"output_address\": \"0x8018\",\n    \"store_width\": 4,  \"store_endianness\": \"little\"\n  }]\n}",
